<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Inject a small style block into <head> on every portal page that
        hides the top navbar and the invoice page's left sidebar card.
        Applied to ALL visitors of the portal frontend, including internal
        users in "preview as customer" mode — they should see the document
        the same way the customer sees it.
    -->
    <template id="hide_portal_chrome_for_customers"
              inherit_id="portal.frontend_layout"
              name="TTS: hide portal chrome for customers">
        <xpath expr="//head" position="inside">
            <style type="text/css">
                /* Top "Your logo" + user menu navbar */
                header,
                header.o_main_navbar,
                nav.o_main_navbar,
                body > nav.navbar { display: none !important; }

                /* ── Left sidebar card (breadcrumb, amount, Pay Now, Download,
                   Salesperson, Powered by odoo) ──────────────────────────────
                   Odoo 17/19 wraps the row inside a .container, so we use
                   descendant selectors (.o_portal_sidebar … .row) rather than
                   direct-child (>). The sidebar column always carries
                   d-print-none; the document column never does. */

                /* Strategy 1 – class-based descendants */
                .o_portal_sidebar .row > div.col-lg-auto,
                .o_portal_sidebar .row > div.col-12.col-lg-auto,
                .o_portal_sidebar .row > div.col-lg-3,
                .o_portal_sidebar .row > div.col-12.col-lg-3,
                .o_portal_sidebar_sidebar,
                .o_portal_my_doc_table + div.col-lg-auto { display: none !important; }

                /* Strategy 2 – d-print-none sidebar column (always present) */
                .o_portal_sidebar .row > div.d-print-none { display: none !important; }

                /* Strategy 3 – known ids / named sections */
                #portal-column-account-move-sidebar,
                #portal_pay,
                .o_portal_invoice_sidebar { display: none !important; }

                /* ── Pay Now / payment buttons anywhere on page ─────────────
                   Belt-and-braces for any Pay button rendered outside the
                   sidebar by an inherited template.                          */
                a[href*="/invoice/transaction/"],
                a[href*="/payment/transaction/"],
                a.btn[href*="transaction"],
                a.o_payment_submit_button,
                button.o_payment_submit_button,
                #o_payment_form_pay,
                .o_portal_pay,
                [name="o_payment_form"],
                .o_portal_sidebar a:has(> .fa-credit-card),
                .o_portal_sidebar .o_portal_pay_button { display: none !important; }

                /* ── Expand document column to full width once sidebar gone ─ */
                .o_portal_sidebar .row > div:not(.d-print-none),
                .o_portal_sidebar .row > div.col-lg,
                .o_portal_sidebar .row > div.col-12.col-lg {
                    flex: 0 0 100% !important;
                    max-width: 100% !important;
                }
            </style>
        </xpath>
    </template>

</odoo>
