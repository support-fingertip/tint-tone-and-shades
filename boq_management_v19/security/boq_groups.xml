<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- BOQ User: can create/edit their own BOQs -->
        <record id="group_boq_user" model="res.groups">
            <field name="name">BOQ User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- BOQ Manager: can approve/reject, see all BOQs -->
        <record id="group_boq_manager" model="res.groups">
            <field name="name">BOQ Manager</field>
            <field name="implied_ids" eval="[(4, ref('group_boq_user'))]"/>
        </record>

        <!--Groups-->
        <record id="group_vendor" model="res.groups">
            <field name="name">Vendor</field>
        </record>

        <record id="group_supplier" model="res.groups">
            <field name="name">Supplier</field>
        </record>


        <!-- Access: Vendor Manager Dashboard only -->
        <record id="group_vendor_manager_dashboard" model="res.groups">
            <field name="name">Vendor Manager Dashboard</field>
            <field name="implied_ids" eval="[(4, ref('group_boq_user')), (4, ref('base.group_partner_manager'))]"/>
        </record>

        <!-- Access: Procurement Manager Dashboard only -->
        <record id="group_procurement_manager_dashboard" model="res.groups">
            <field name="name">Procurement Manager Dashboard</field>
            <field name="implied_ids" eval="[(4, ref('group_boq_user')), (4, ref('base.group_partner_manager'))]"/>
        </record>

        <!-- Access: Head of Supplier Dashboard (senior/manager view) -->
        <record id="group_head_supplier_dashboard" model="res.groups">
            <field name="name">Head of Supplier Dashboard</field>
            <field name="implied_ids" eval="[(4, ref('group_boq_manager'))]"/>
        </record>

    </data>
</odoo>
