<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<!--
    BOQ Manager Dashboard Template
    ================================
    Task 1  — Two separate dashboards (same template, dashboardType drives labels)
    Task 2  — Expandable Trade → Vendor → RFQ tree (3 levels)
    Task 4  — Renamed labels, no "lines", payment status, Draft → "Quote Requested"
    Task 5  — Multi-company via allowed_company_ids in RPC
-->
<t t-name="boq_management_v19.BoqManagerDashboard">
    <div class="boq_dashboard o_action"
         data-bs-theme="light"
         style="display:flex;flex-direction:column;height:100%;
                color-scheme:light;background:#f8f9fa;color:#212529;">

        <!-- ── LOADING ───────────────────────────────────────────────── -->
        <t t-if="state.loading">
            <div class="d-flex flex-column align-items-center justify-content-center"
                 style="flex:1;min-height:0;">
                <div class="spinner-border text-primary mb-3"
                     style="width:3rem;height:3rem;" role="status">
                    <span class="visually-hidden">Loading…</span>
                </div>
                <p class="text-muted fw-semibold">
                    Loading <t t-esc="dashboardTitle"/>…
                </p>
            </div>
        </t>

        <!-- ── ERROR ────────────────────────────────────────────────── -->
        <t t-elif="state.error">
            <div class="alert alert-danger m-4">
                <i class="fa fa-exclamation-triangle me-2"/>
                <strong>Dashboard Error:</strong>
                <t t-esc="state.error"/>
                <button class="btn btn-sm btn-outline-danger ms-3"
                        t-on-click="refresh">Retry</button>
            </div>
        </t>

        <!-- ── MAIN ─────────────────────────────────────────────────── -->
        <t t-else="">

            <!-- ╔═══════════════════════════════════════════════╗
                 ║  PINNED HEADER                                ║
                 ╚═══════════════════════════════════════════════╝ -->
            <div class="boq_dash_header d-flex align-items-center
                        justify-content-between px-4 py-3 border-bottom">
                <div class="d-flex align-items-center gap-3">
                    <i t-attf-class="fa {{ dashboardIcon }} fa-2x text-primary"/>
                    <div>
                        <!-- Task 4.1 — renamed title -->
                        <h4 class="mb-0 fw-bold"><t t-esc="dashboardTitle"/></h4>
                        <small class="text-muted"><t t-esc="dashboardSubtitle"/></small>
                    </div>
                </div>
                <div class="d-flex gap-2 align-items-center">
                    <!-- Search / filter -->
                    <div class="input-group input-group-sm" style="width:200px;">
                        <span class="input-group-text bg-white">
                            <i class="fa fa-search text-muted"/>
                        </span>
                        <input type="text"
                               class="form-control"
                               placeholder="Filter trade / vendor…"
                               t-model="state.filterText"/>
                        <button t-attf-class="btn btn-outline-secondary {{ state.filterText ? '' : 'invisible' }}"
                                t-on-click="clearFilter" title="Clear">
                            <i class="fa fa-times"/>
                        </button>
                    </div>
                    <button class="btn btn-sm btn-outline-primary" t-on-click="openAllBoqs">
                        <i class="fa fa-calculator me-1"/>All BOQs
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" t-on-click="openRfqs">
                        <i class="fa fa-shopping-cart me-1"/>RFQs
                    </button>
                    <button class="btn btn-sm btn-light" t-on-click="refresh">
                        <i class="fa fa-refresh me-1"/>Refresh
                    </button>
                </div>
            </div>

            <!-- ╔═══════════════════════════════════════════════╗
                 ║  SCROLLABLE BODY                              ║
                 ╚═══════════════════════════════════════════════╝ -->
            <div class="boq_dash_scroll">

                <!-- ── STAT CARDS ─────────────────────────── -->
                <div class="boq_dash_stat_row d-flex flex-wrap gap-3 p-4">

                    <div class="boq_stat_card flex-fill" t-on-click="openAllBoqs"
                         style="cursor:pointer;">
                        <div class="boq_stat_icon bg-primary-subtle text-primary">
                            <i class="fa fa-calculator fa-2x"/>
                        </div>
                        <div class="boq_stat_body">
                            <div class="boq_stat_value">
                                <t t-esc="state.stats.total_boqs || 0"/>
                            </div>
                            <div class="boq_stat_label">Total BOQs</div>
                        </div>
                    </div>

                    <div class="boq_stat_card flex-fill">
                        <div class="boq_stat_icon bg-success-subtle text-success">
                            <i class="fa fa-money fa-2x"/>
                        </div>
                        <div class="boq_stat_body">
                            <div class="boq_stat_value small">
                                <t t-esc="fmtCurrency(state.stats.total_value)"/>
                            </div>
                            <div class="boq_stat_label">BOQ Untaxed Amount</div>
                        </div>
                    </div>

                    <div class="boq_stat_card flex-fill">
                        <div class="boq_stat_icon bg-warning-subtle text-warning">
                            <i class="fa fa-bar-chart fa-2x"/>
                        </div>
                        <div class="boq_stat_body">
                            <div class="boq_stat_value small">
                                <t t-esc="fmtCurrency(state.stats.grand_total)"/>
                            </div>
                            <div class="boq_stat_label">Grand Total (incl. Tax)</div>
                        </div>
                    </div>

                    <div class="boq_stat_card flex-fill" t-on-click="openRfqs"
                         style="cursor:pointer;">
                        <div class="boq_stat_icon bg-info-subtle text-info">
                            <i class="fa fa-shopping-cart fa-2x"/>
                        </div>
                        <div class="boq_stat_body">
                            <div class="boq_stat_value">
                                <t t-esc="state.stats.total_rfqs || 0"/>
                            </div>
                            <div class="boq_stat_label">
                                Total RFQs
                                <span class="badge bg-warning text-dark ms-1 small">
                                    <t t-esc="state.stats.rfq_draft || 0"/> pending
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="boq_stat_card flex-fill">
                        <div class="boq_stat_icon bg-secondary-subtle text-secondary">
                            <i class="fa fa-money fa-2x"/>
                        </div>
                        <div class="boq_stat_body">
                            <div class="boq_stat_value small">
                                <t t-esc="fmtCurrency(state.stats.rfq_total_value)"/>
                            </div>
                            <div class="boq_stat_label">RFQ Value</div>
                        </div>
                    </div>

                </div><!-- /stat cards -->

                <!-- ── TREE SUMMARY BAR ──────────────────────── -->
                <div class="boq_tree_summary_bar d-flex flex-wrap gap-3 px-4 pb-3">
                    <span class="boq_totals_chip">
                        <i class="fa fa-wrench me-1"/>
                        <strong><t t-esc="treeTotals.trades"/></strong> Trade<t t-if="treeTotals.trades !== 1">s</t>
                    </span>
                    <span class="boq_totals_chip">
                        <i t-attf-class="fa {{ dashboardIcon }} me-1"/>
                        <strong><t t-esc="treeTotals.vendors"/></strong>
                        <t t-esc="partnerLabel"/><t t-if="treeTotals.vendors !== 1">s</t>
                    </span>
                    <span class="boq_totals_chip">
                        <i class="fa fa-shopping-cart me-1"/>
                        <strong><t t-esc="treeTotals.rfqs"/></strong> RFQs
                    </span>
                    <span class="boq_totals_chip boq_chip_warning">
                        <i class="fa fa-clock-o me-1"/>
                        <strong><t t-esc="treeTotals.pending"/></strong> Pending
                    </span>
                    <t t-if="treeTotals.submitted > 0">
                        <span class="boq_totals_chip boq_chip_success">
                            <i class="fa fa-check-circle me-1"/>
                            <strong><t t-esc="treeTotals.submitted"/></strong> Recently Submitted
                        </span>
                    </t>
                    <span class="boq_totals_chip boq_totals_value ms-auto">
                        <i class="fa fa-money me-1"/>
                        <strong><t t-esc="fmtCurrency(treeTotals.value)"/></strong>
                    </span>
                </div>

                <!-- ╔═══════════════════════════════════════════════╗
                     ║  3-LEVEL EXPANDABLE TREE                      ║
                     ║  Level 1: Trade rows                          ║
                     ║  Level 2: Vendor rows (expand from trade)     ║
                     ║  Level 3: RFQ rows (expand from vendor)       ║
                     ╚═══════════════════════════════════════════════╝ -->
                <div class="px-4 pb-4">

                    <!-- Empty state -->
                    <t t-if="filteredTree.length === 0">
                        <div class="text-center py-5 text-muted">
                            <i class="fa fa-info-circle fa-3x mb-3 d-block text-primary opacity-50"/>
                            <t t-if="state.filterText">
                                <p class="fw-semibold">No results match "<t t-esc="state.filterText"/>"</p>
                                <button class="btn btn-sm btn-outline-secondary"
                                        t-on-click="clearFilter">Clear filter</button>
                            </t>
                            <t t-else="">
                                <p class="fw-semibold">No trade assignments yet.</p>
                                <small>
                                    Open a BOQ, select Work Categories, assign
                                    <t t-esc="partnerLabel"/>s, then click <b>Create RFQ</b>.
                                </small>
                            </t>
                        </div>
                    </t>

                    <!-- Tree table -->
                    <t t-else="">
                        <div class="boq_tree_table">

                            <!-- ── TRADE ROWS (Level 1) ─────────────── -->
                            <t t-foreach="filteredTree" t-as="trade" t-key="trade.trade_id">

                                <!-- Trade row -->
                                <div t-attf-class="boq_tree_row boq_trade_row
                                                   {{ isTradeExpanded(trade.trade_id) ? 'boq_trade_row_open' : '' }}"
                                     t-on-click="() => this.toggleTrade(trade.trade_id)">

                                    <!-- Expand icon -->
                                    <span class="boq_tree_expand_icon">
                                        <i t-attf-class="fa {{ isTradeExpanded(trade.trade_id) ? 'fa-chevron-down' : 'fa-chevron-right' }}"/>
                                    </span>

                                    <!-- Trade icon + name -->
                                    <span class="boq_tree_label">
                                        <i t-attf-class="fa {{ trade.trade_icon || 'fa-cogs' }} me-2 text-primary"/>
                                        <strong><t t-esc="trade.trade_name"/></strong>
                                    </span>

                                    <!-- Trade stats -->
                                    <span class="boq_tree_chips">
                                        <span class="badge bg-info rounded-pill me-1" title="Vendors / Suppliers">
                                            <i t-attf-class="fa {{ dashboardIcon }} me-1"/>
                                            <t t-esc="trade.vendor_count"/>
                                        </span>
                                        <span class="badge bg-primary rounded-pill me-1" title="RFQs">
                                            <i class="fa fa-shopping-cart me-1"/>
                                            <t t-esc="trade.rfq_count"/>
                                        </span>
                                        <t t-if="trade.pending_count > 0">
                                            <span class="badge bg-warning text-dark rounded-pill me-1"
                                                  title="Pending — RFQ sent but no quotation yet">
                                                <i class="fa fa-clock-o me-1"/>
                                                <t t-esc="trade.pending_count"/> pending
                                            </span>
                                        </t>
                                        <t t-if="trade.submitted_count > 0">
                                            <span class="badge bg-success rounded-pill me-1"
                                                  title="Quotation submitted recently">
                                                <i class="fa fa-check-circle me-1"/>
                                                <t t-esc="trade.submitted_count"/> new
                                            </span>
                                        </t>
                                    </span>

                                    <!-- Trade total value -->
                                    <span class="boq_tree_value ms-auto fw-bold">
                                        <t t-esc="fmtCurrency(trade.total_value)"/>
                                    </span>
                                </div><!-- /trade row -->

                                <!-- ── VENDOR ROWS (Level 2) — shown when trade expanded ── -->
                                <t t-if="isTradeExpanded(trade.trade_id)">
                                    <t t-if="trade.vendors.length === 0">
                                        <div class="boq_tree_row boq_vendor_row boq_empty_row">
                                            <span class="text-muted small ms-4 ps-2">
                                                <i class="fa fa-info-circle me-1"/>
                                                No <t t-esc="partnerLabel"/>s assigned to this trade yet.
                                            </span>
                                        </div>
                                    </t>
                                    <t t-foreach="trade.vendors" t-as="vendor"
                                       t-key="vendor.vendor_id">

                                        <!-- Vendor row -->
                                        <div t-attf-class="boq_tree_row boq_vendor_row
                                                           {{ isVendorExpanded(vendor.vendor_id) ? 'boq_vendor_row_open' : '' }}"
                                             t-on-click="() => this.toggleVendor(vendor.vendor_id)">

                                            <!-- Indent spacer -->
                                            <span class="boq_tree_indent"/>

                                            <!-- Expand icon -->
                                            <span class="boq_tree_expand_icon">
                                                <i t-attf-class="fa {{ isVendorExpanded(vendor.vendor_id) ? 'fa-chevron-down' : 'fa-chevron-right' }}"/>
                                            </span>

                                            <!-- Avatar + name -->
                                            <span class="boq_vendor_avatar_sm">
                                                <t t-esc="(vendor.vendor_name || '?').charAt(0).toUpperCase()"/>
                                            </span>
                                            <span class="boq_tree_label">
                                                <span class="fw-semibold">
                                                    <t t-esc="vendor.vendor_name"/>
                                                </span>
                                                <t t-if="vendor.vendor_email">
                                                    <small class="text-muted ms-2">
                                                        <t t-esc="vendor.vendor_email"/>
                                                    </small>
                                                </t>
                                            </span>

                                            <!-- Vendor badges -->
                                            <span class="boq_tree_chips">
                                                <span class="badge bg-primary rounded-pill me-1"
                                                      title="Total RFQs">
                                                    <t t-esc="vendor.rfq_count"/> RFQ<t t-if="vendor.rfq_count !== 1">s</t>
                                                </span>

                                                <!-- Pending indicator (Task 2.5) -->
                                                <t t-if="vendor.pending_count > 0">
                                                    <span class="badge bg-warning text-dark rounded-pill me-1"
                                                          title="RFQ sent — awaiting quotation">
                                                        <i class="fa fa-clock-o me-1"/>
                                                        <t t-esc="vendor.pending_count"/> pending
                                                    </span>
                                                </t>

                                                <!-- Recently submitted notification (Task 2.6) -->
                                                <t t-if="vendor.recently_submitted_count > 0">
                                                    <span class="badge boq_badge_new rounded-pill me-1"
                                                          title="Quotation submitted in last 7 days">
                                                        <i class="fa fa-bell me-1"/>
                                                        <t t-esc="vendor.recently_submitted_count"/> new
                                                    </span>
                                                </t>

                                                <!-- Payment status badge (Task 4.5) -->
                                                <span t-attf-class="badge {{ paymentStatusClass(vendor.payment_status) }} rounded-pill">
                                                    <t t-esc="vendor.payment_status_label"/>
                                                </span>
                                            </span>

                                            <!-- Vendor total value -->
                                            <span class="boq_tree_value fw-semibold">
                                                <t t-esc="fmtCurrency(vendor.total_value)"/>
                                            </span>

                                            <!-- Open vendor RFQs link -->
                                            <span class="boq_tree_action ms-2"
                                                  t-on-click.stop="() => this.openVendorRfqs(vendor.vendor_id, vendor.vendor_name)"
                                                  title="Open all RFQs for this vendor">
                                                <i class="fa fa-external-link text-muted"/>
                                            </span>
                                        </div><!-- /vendor row -->

                                        <!-- ── RFQ ROWS (Level 3) ── -->
                                        <!-- Task 2.4: No payment info in vendor-expanded section -->
                                        <t t-if="isVendorExpanded(vendor.vendor_id)">
                                            <t t-if="vendor.rfqs.length === 0">
                                                <div class="boq_tree_row boq_rfq_row boq_empty_row">
                                                    <span class="text-muted small ms-5 ps-3">
                                                        <i class="fa fa-info-circle me-1"/>
                                                        No RFQs yet for this <t t-esc="partnerLabel"/>.
                                                    </span>
                                                </div>
                                            </t>
                                            <t t-foreach="vendor.rfqs" t-as="rfq"
                                               t-key="rfq.rfq_id">
                                                <div t-attf-class="boq_tree_row boq_rfq_row
                                                                   {{ rfq.is_recently_submitted ? 'boq_rfq_row_new' : '' }}"
                                                     t-on-click.stop="() => this.openRfq(rfq.rfq_id)"
                                                     style="cursor:pointer;">

                                                    <!-- Double indent -->
                                                    <span class="boq_tree_indent"/>
                                                    <span class="boq_tree_indent"/>

                                                    <!-- RFQ reference -->
                                                    <span class="boq_tree_label">
                                                        <i class="fa fa-file-text-o me-2 text-muted"/>
                                                        <span class="fw-semibold text-primary">
                                                            <t t-esc="rfq.rfq_name"/>
                                                        </span>
                                                        <t t-if="rfq.date_order">
                                                            <small class="text-muted ms-2">
                                                                <t t-esc="rfq.date_order"/>
                                                            </small>
                                                        </t>
                                                    </span>

                                                    <!-- RFQ state (Task 4.6: Draft → "Quote Requested") -->
                                                    <span class="boq_tree_chips">
                                                        <span t-attf-class="badge {{ rfqStateClass(rfq.state) }} rounded-pill">
                                                            <t t-esc="rfq.state_label"/>
                                                        </span>
                                                        <!-- Recently submitted bell (Task 2.6) -->
                                                        <t t-if="rfq.is_recently_submitted">
                                                            <span class="badge boq_badge_new rounded-pill ms-1"
                                                                  title="Submitted in last 7 days">
                                                                <i class="fa fa-bell me-1"/>New
                                                            </span>
                                                        </t>
                                                        <!-- Pending indicator -->
                                                        <t t-if="rfq.is_pending">
                                                            <span class="badge bg-warning text-dark rounded-pill ms-1"
                                                                  title="Awaiting vendor quotation">
                                                                <i class="fa fa-clock-o me-1"/>Pending
                                                            </span>
                                                        </t>
                                                    </span>

                                                    <!-- RFQ amount -->
                                                    <span class="boq_tree_value text-muted">
                                                        <t t-esc="fmtCurrency(rfq.amount_total)"/>
                                                    </span>

                                                    <!-- Open link -->
                                                    <span class="boq_tree_action ms-2">
                                                        <i class="fa fa-external-link text-muted"/>
                                                    </span>
                                                </div><!-- /rfq row -->
                                            </t>
                                        </t><!-- /rfqs expanded -->

                                    </t><!-- /vendor foreach -->
                                </t><!-- /vendors expanded -->

                            </t><!-- /trade foreach -->
                        </div><!-- /boq_tree_table -->
                    </t>

                </div><!-- /tree container px-4 -->

            </div><!-- /scrollable body -->
        </t><!-- /main -->
    </div><!-- /root -->
</t>

</templates>
