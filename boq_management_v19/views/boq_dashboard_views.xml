<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Task 1 — Two Separate Dashboard Pages
        ======================================
        Replaced single "BOQ Dashboard" action with two fully separate
        client actions:
          1. Vendor Manager Dashboard  (dashboard_type = vendor)
          2. Procurement Manager Dashboard (dashboard_type = supplier)
        Each maps to the same OWL component tag but with a different
        context so the component knows which data to load.
    -->

    <!-- ═══════════════════════════════════════════════════════════════════
         VENDOR MANAGER DASHBOARD — ir.actions.client
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="action_vendor_manager_dashboard" model="ir.actions.client">
        <field name="name">Vendor Manager Dashboard</field>
        <field name="tag">boq_management_v19.manager_dashboard_action</field>
        <field name="target">current</field>
        <field name="context">{"dashboard_type": "vendor"}</field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════
         PROCUREMENT MANAGER DASHBOARD — ir.actions.client
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="action_procurement_manager_dashboard" model="ir.actions.client">
        <field name="name">Procurement Manager Dashboard</field>
        <field name="tag">boq_management_v19.manager_dashboard_action</field>
        <field name="target">current</field>
        <field name="context">{"dashboard_type": "supplier"}</field>
    </record>

</odoo>
