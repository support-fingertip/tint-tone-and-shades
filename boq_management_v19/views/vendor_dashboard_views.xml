<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ╔═══════════════════════════════════════════════════════════════╗
         ║  1. KANBAN VIEW — Vendor Cards                                ║
         ╚═══════════════════════════════════════════════════════════════╝ -->
    <record id="view_vendor_dashboard_kanban" model="ir.ui.view">
        <field name="name">res.partner.vendor.dashboard.kanban</field>
        <field name="model">res.partner</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <kanban create="0" edit="0" delete="0"
                    default_order="vendor_rating_avg desc, name asc"
                    sample="1">
                <!-- NOTE: 'color' field intentionally NOT listed here
                     to prevent Odoo's auto-color CSS from overriding text colours -->
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="vendor_rating_avg"/>
                <field name="vendor_rating_count"/>
                <field name="vendor_rating_status"/>
                <field name="vendor_rating_percent"/>
                <field name="vendor_po_count"/>
                <field name="vendor_po_total"/>
                <field name="vendor_po_paid_count"/>
                <field name="vendor_po_pending_count"/>
                <field name="vendor_trade_names"/>
                <field name="vendor_boq_line_count"/>
                <field name="vendor_margin_percent"/>
                <field name="vendor_payment_ratio"/>
                <field name="vendor_quality_avg"/>
                <field name="vendor_delivery_avg"/>
                <field name="vendor_pricing_avg"/>
                <field name="vendor_communication_avg"/>
                <field name="image_128"/>
                <templates>
                    <t t-name="card">

                        <!-- TOP COLOUR BAR — single t-attf-style only (no duplicate style=) -->
                        <div t-attf-style="
                            height:6px;
                            margin:-12px -12px 14px -12px;
                            border-radius:6px 6px 0 0;
                            background:{{
                                record.vendor_rating_status.raw_value === 'excellent'
                                    ? 'linear-gradient(90deg,#28a745,#20c997)'
                                : record.vendor_rating_status.raw_value === 'good'
                                    ? 'linear-gradient(90deg,#0d6efd,#17a2b8)'
                                : record.vendor_rating_status.raw_value === 'average'
                                    ? 'linear-gradient(90deg,#ffc107,#fd7e14)'
                                : record.vendor_rating_status.raw_value === 'low'
                                    ? 'linear-gradient(90deg,#dc3545,#e05929)'
                                : 'linear-gradient(90deg,#adb5bd,#868e96)'
                            }};
                        "/>

                        <!-- AVATAR + NAME — use t-esc so text colour is never overridden -->
                        <div class="d-flex align-items-start gap-2 mb-2">
                            <div style="flex-shrink:0;">
                                <field name="image_128" widget="image"
                                       style="width:46px;height:46px;border-radius:50%;object-fit:cover;border:2px solid #dee2e6;"
                                       options="{'size':[46,46]}"/>
                            </div>
                            <div style="flex:1;min-width:0;margin-top:2px;">
                                <!-- t-esc for name ensures text is always visible -->
                                <div class="fw-bold text-truncate"
                                     style="font-size:0.93rem;color:#1a1a2e;line-height:1.3;">
                                    <t t-esc="record.name.value"/>
                                </div>
                                <div class="text-truncate"
                                     style="font-size:0.74rem;color:#6c757d;margin-bottom:4px;">
                                    <t t-esc="record.email.value || '—'"/>
                                </div>
                                <field name="vendor_rating_status" widget="badge"
                                       decoration-success="vendor_rating_status == 'excellent'"
                                       decoration-info="vendor_rating_status == 'good'"
                                       decoration-warning="vendor_rating_status == 'average'"
                                       decoration-danger="vendor_rating_status == 'low'"/>
                            </div>
                        </div>

                        <!-- STARS + SCORE -->
                        <div class="d-flex align-items-center gap-1 mb-1" style="color:#1a1a2e;">
                            <t t-set="avg_val" t-value="Math.round(record.vendor_rating_avg.raw_value || 0)"/>
                            <span style="color:#ffc107;letter-spacing:1px;font-size:0.95rem;">
                                <i t-attf-class="fa {{ avg_val >= 1 ? 'fa-star' : 'fa-star-o' }}"/>
                                <i t-attf-class="fa {{ avg_val >= 2 ? 'fa-star' : 'fa-star-o' }}"/>
                                <i t-attf-class="fa {{ avg_val >= 3 ? 'fa-star' : 'fa-star-o' }}"/>
                                <i t-attf-class="fa {{ avg_val >= 4 ? 'fa-star' : 'fa-star-o' }}"/>
                                <i t-attf-class="fa {{ avg_val >= 5 ? 'fa-star' : 'fa-star-o' }}"/>
                            </span>
                            <span class="fw-bold ms-1" style="font-size:0.9rem;color:#1a1a2e;">
                                <field name="vendor_rating_avg" widget="float" digits="[3,1]"/>
                            </span>
                            <span class="ms-auto" style="font-size:0.7rem;color:#adb5bd;">
                                <t t-esc="record.vendor_rating_count.raw_value || 0"/> ratings
                            </span>
                        </div>

                        <!-- RATING PROGRESS BAR -->
                        <div class="mb-2"
                             style="height:6px;background:#e9ecef;border-radius:4px;overflow:hidden;">
                            <div t-attf-style="
                                height:100%;
                                border-radius:4px;
                                transition:width 0.3s ease;
                                width:{{ Math.min(record.vendor_rating_percent.raw_value || 0, 100) }}%;
                                background:{{
                                    record.vendor_rating_status.raw_value === 'excellent' ? '#28a745' :
                                    record.vendor_rating_status.raw_value === 'good'      ? '#0d6efd' :
                                    record.vendor_rating_status.raw_value === 'average'   ? '#ffc107' :
                                    record.vendor_rating_status.raw_value === 'low'       ? '#dc3545' : '#adb5bd'
                                }};
                            "/>
                        </div>

                        <!-- TRADE TAGS -->
                        <div class="mb-2" style="font-size:0.73rem;color:#495057;min-height:18px;">
                            <i class="fa fa-wrench me-1" style="color:#6f42c1;"/>
                            <t t-esc="record.vendor_trade_names.value || 'No trades assigned'"/>
                        </div>

                        <!-- PO STATS GRID (4 columns) -->
                        <div class="d-flex text-center mb-2"
                             style="border:1px solid #e9ecef;border-radius:6px;overflow:hidden;background:#f8f9fa;">
                            <div style="flex:1;padding:7px 3px;border-right:1px solid #e9ecef;">
                                <div class="fw-bold" style="font-size:0.95rem;color:#0d6efd;">
                                    <t t-esc="record.vendor_po_count.raw_value || 0"/>
                                </div>
                                <div style="font-size:0.6rem;color:#6c757d;text-transform:uppercase;">POs</div>
                            </div>
                            <div style="flex:1;padding:7px 3px;border-right:1px solid #e9ecef;">
                                <div class="fw-bold" style="font-size:0.95rem;color:#28a745;">
                                    <t t-esc="record.vendor_po_paid_count.raw_value || 0"/>
                                </div>
                                <div style="font-size:0.6rem;color:#6c757d;text-transform:uppercase;">Paid</div>
                            </div>
                            <div style="flex:1;padding:7px 3px;border-right:1px solid #e9ecef;">
                                <div class="fw-bold" style="font-size:0.95rem;color:#fd7e14;">
                                    <t t-esc="record.vendor_po_pending_count.raw_value || 0"/>
                                </div>
                                <div style="font-size:0.6rem;color:#6c757d;text-transform:uppercase;">Pending</div>
                            </div>
                            <div style="flex:1;padding:7px 3px;">
                                <div class="fw-bold" style="font-size:0.95rem;color:#6f42c1;">
                                    <t t-esc="record.vendor_boq_line_count.raw_value || 0"/>
                                </div>
                                <div style="font-size:0.6rem;color:#6c757d;text-transform:uppercase;">Lines</div>
                            </div>
                        </div>

                        <!-- SUB-RATING BARS (written explicitly — avoids t-foreach array issues) -->
                        <t t-if="record.vendor_rating_count.raw_value > 0">
                            <div style="font-size:0.72rem;margin-bottom:10px;">

                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <span style="width:50px;color:#6c757d;flex-shrink:0;">Quality</span>
                                    <div style="flex:1;height:5px;background:#e9ecef;border-radius:3px;overflow:hidden;">
                                        <div t-attf-style="height:100%;border-radius:3px;background:#28a745;width:{{ ((record.vendor_quality_avg.raw_value || 0) / 5) * 100 }}%;"/>
                                    </div>
                                    <span style="width:24px;text-align:right;color:#1a1a2e;font-weight:600;">
                                        <t t-if="record.vendor_quality_avg.raw_value">
                                            <t t-esc="record.vendor_quality_avg.raw_value.toFixed(1)"/>
                                        </t>
                                        <t t-else="">—</t>
                                    </span>
                                </div>

                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <span style="width:50px;color:#6c757d;flex-shrink:0;">Delivery</span>
                                    <div style="flex:1;height:5px;background:#e9ecef;border-radius:3px;overflow:hidden;">
                                        <div t-attf-style="height:100%;border-radius:3px;background:#17a2b8;width:{{ ((record.vendor_delivery_avg.raw_value || 0) / 5) * 100 }}%;"/>
                                    </div>
                                    <span style="width:24px;text-align:right;color:#1a1a2e;font-weight:600;">
                                        <t t-if="record.vendor_delivery_avg.raw_value">
                                            <t t-esc="record.vendor_delivery_avg.raw_value.toFixed(1)"/>
                                        </t>
                                        <t t-else="">—</t>
                                    </span>
                                </div>

                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <span style="width:50px;color:#6c757d;flex-shrink:0;">Pricing</span>
                                    <div style="flex:1;height:5px;background:#e9ecef;border-radius:3px;overflow:hidden;">
                                        <div t-attf-style="height:100%;border-radius:3px;background:#6f42c1;width:{{ ((record.vendor_pricing_avg.raw_value || 0) / 5) * 100 }}%;"/>
                                    </div>
                                    <span style="width:24px;text-align:right;color:#1a1a2e;font-weight:600;">
                                        <t t-if="record.vendor_pricing_avg.raw_value">
                                            <t t-esc="record.vendor_pricing_avg.raw_value.toFixed(1)"/>
                                        </t>
                                        <t t-else="">—</t>
                                    </span>
                                </div>

                                <div class="d-flex align-items-center gap-2">
                                    <span style="width:50px;color:#6c757d;flex-shrink:0;">Comms</span>
                                    <div style="flex:1;height:5px;background:#e9ecef;border-radius:3px;overflow:hidden;">
                                        <div t-attf-style="height:100%;border-radius:3px;background:#fd7e14;width:{{ ((record.vendor_communication_avg.raw_value || 0) / 5) * 100 }}%;"/>
                                    </div>
                                    <span style="width:24px;text-align:right;color:#1a1a2e;font-weight:600;">
                                        <t t-if="record.vendor_communication_avg.raw_value">
                                            <t t-esc="record.vendor_communication_avg.raw_value.toFixed(1)"/>
                                        </t>
                                        <t t-else="">—</t>
                                    </span>
                                </div>

                            </div>
                        </t>

                        <!-- PO VALUE + MARGIN -->
                        <div class="d-flex justify-content-between align-items-end"
                             style="border-top:1px solid #f0f0f0;padding-top:8px;">
                            <div>
                                <div style="font-size:0.67rem;color:#adb5bd;text-transform:uppercase;letter-spacing:0.4px;">
                                    PO Value
                                </div>
                                <div class="fw-bold" style="color:#0d6efd;font-size:0.88rem;">
                                    <field name="vendor_po_total" widget="monetary"/>
                                </div>
                            </div>
                            <div class="text-end">
                                <div style="font-size:0.67rem;color:#adb5bd;text-transform:uppercase;letter-spacing:0.4px;">
                                    Margin
                                </div>
                                <div class="fw-bold" t-attf-style="font-size:0.88rem;color:{{
                                    record.vendor_margin_percent.raw_value >= 30  ? '#28a745' :
                                    record.vendor_margin_percent.raw_value >= 15  ? '#17a2b8' :
                                    record.vendor_margin_percent.raw_value >= 0   ? '#fd7e14' : '#dc3545'
                                }};">
                                    <field name="vendor_margin_percent" widget="float" digits="[6,1]"/>%
                                </div>
                            </div>
                        </div>

                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ╔═══════════════════════════════════════════════════════════════╗
         ║  2. LIST VIEW                                                  ║
         ╚═══════════════════════════════════════════════════════════════╝ -->
    <record id="view_vendor_dashboard_list" model="ir.ui.view">
        <field name="name">res.partner.vendor.dashboard.list</field>
        <field name="model">res.partner</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <list string="Vendor Dashboard" create="0" edit="0" delete="0"
                  default_order="vendor_rating_avg desc, name asc"
                  decoration-success="vendor_rating_status == 'excellent'"
                  decoration-info="vendor_rating_status == 'good'"
                  decoration-warning="vendor_rating_status == 'average'"
                  decoration-danger="vendor_rating_status == 'low'">
                <field name="name" string="Vendor"/>
                <field name="email" optional="show"/>
                <field name="phone" optional="hide"/>
                <field name="vendor_rating_avg" string="Rating" widget="float" digits="[3,1]"/>
                <field name="vendor_rating_percent" string="Rating %" widget="progressbar"
                       options="{'editable': false}" optional="show"/>
                <field name="vendor_rating_count" string="Rated POs"/>
                <field name="vendor_rating_status" string="Status" widget="badge"
                       decoration-success="vendor_rating_status == 'excellent'"
                       decoration-info="vendor_rating_status == 'good'"
                       decoration-warning="vendor_rating_status == 'average'"
                       decoration-danger="vendor_rating_status == 'low'"/>
                <field name="vendor_quality_avg" string="Quality" widget="float" digits="[3,1]" optional="show"/>
                <field name="vendor_delivery_avg" string="Delivery" widget="float" digits="[3,1]" optional="show"/>
                <field name="vendor_pricing_avg" string="Pricing" widget="float" digits="[3,1]" optional="hide"/>
                <field name="vendor_communication_avg" string="Comm." widget="float" digits="[3,1]" optional="hide"/>
                <field name="vendor_trade_names" string="Trades"/>
                <field name="vendor_margin_percent" string="Margin %"
                       decoration-success="vendor_margin_percent &gt;= 30"
                       decoration-info="vendor_margin_percent &gt;= 15 and vendor_margin_percent &lt; 30"
                       decoration-warning="vendor_margin_percent &gt;= 0 and vendor_margin_percent &lt; 15"
                       decoration-danger="vendor_margin_percent &lt; 0"
                       optional="show"/>
                <field name="vendor_po_count" string="POs"/>
                <field name="vendor_po_total" string="PO Value" widget="monetary"/>
                <field name="vendor_payment_ratio" string="Payment"/>
                <field name="vendor_po_paid_count" string="Paid" optional="hide"/>
                <field name="vendor_po_pending_count" string="Pending" optional="hide"/>
                <field name="city" optional="hide"/>
                <field name="country_id" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ╔═══════════════════════════════════════════════════════════════╗
         ║  3. FORM VIEW — Vendor Detail                                 ║
         ╚═══════════════════════════════════════════════════════════════╝ -->
    <record id="view_vendor_dashboard_form" model="ir.ui.view">
        <field name="name">res.partner.vendor.dashboard.form</field>
        <field name="model">res.partner</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <form string="Vendor Dashboard" create="0" delete="0">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_view_vendor_pos"
                                class="oe_stat_button" icon="fa-shopping-cart">
                            <field name="vendor_po_count" widget="statinfo" string="Purchase Orders"/>
                        </button>
                        <button type="object" name="action_view_vendor_ratings"
                                class="oe_stat_button" icon="fa-star"
                                invisible="vendor_rating_count == 0">
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field name="vendor_rating_avg" widget="float" digits="[3,1]"/> / 5
                                </span>
                                <span class="o_stat_text">Rating (<field name="vendor_rating_count"/> POs)</span>
                            </div>
                        </button>
                        <button type="object" name="action_view_vendor_boq_lines"
                                class="oe_stat_button" icon="fa-list"
                                invisible="vendor_boq_line_count == 0">
                            <field name="vendor_boq_line_count" widget="statinfo" string="BOQ Lines"/>
                        </button>
                        <button type="object" name="action_view_boqs"
                                class="oe_stat_button" icon="fa-calculator"
                                invisible="boq_count == 0">
                            <field name="boq_count" widget="statinfo" string="BOQs"/>
                        </button>
                    </div>

                    <widget name="web_ribbon" title="Excellent"
                            invisible="vendor_rating_status != 'excellent'" bg_color="text-bg-success"/>
                    <widget name="web_ribbon" title="Good"
                            invisible="vendor_rating_status != 'good'" bg_color="text-bg-info"/>
                    <widget name="web_ribbon" title="Average"
                            invisible="vendor_rating_status != 'average'" bg_color="text-bg-warning"/>
                    <widget name="web_ribbon" title="Low Rating"
                            invisible="vendor_rating_status != 'low'" bg_color="text-bg-danger"/>

                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <group>
                        <group string="Vendor Information">
                            <field name="email" readonly="1"/>
                            <field name="phone" readonly="1"/>
                            <field name="city" readonly="1"/>
                            <field name="country_id" readonly="1"/>
                        </group>
                        <group string="Overall Rating">
                            <field name="vendor_rating_avg" readonly="1" widget="float" digits="[3,1]"/>
                            <field name="vendor_rating_count" readonly="1"/>
                            <field name="vendor_rating_status" readonly="1" widget="badge"
                                   decoration-success="vendor_rating_status == 'excellent'"
                                   decoration-info="vendor_rating_status == 'good'"
                                   decoration-warning="vendor_rating_status == 'average'"
                                   decoration-danger="vendor_rating_status == 'low'"/>
                            <field name="vendor_rating_percent" readonly="1" widget="progressbar"
                                   options="{'editable': false}"/>
                        </group>
                    </group>
                    <group>
                        <group string="Rating Breakdown">
                            <field name="vendor_quality_avg" readonly="1" string="Quality"
                                   widget="float" digits="[3,1]"/>
                            <field name="vendor_delivery_avg" readonly="1" string="Delivery"
                                   widget="float" digits="[3,1]"/>
                            <field name="vendor_pricing_avg" readonly="1" string="Pricing"
                                   widget="float" digits="[3,1]"/>
                            <field name="vendor_communication_avg" readonly="1" string="Communication"
                                   widget="float" digits="[3,1]"/>
                        </group>
                        <group string="Trade &amp; Financial">
                            <field name="vendor_trade_names" readonly="1" string="Trades"/>
                            <field name="vendor_boq_line_count" readonly="1" string="BOQ Lines"/>
                            <field name="vendor_boq_line_total" readonly="1" string="BOQ Value"
                                   widget="monetary"/>
                            <field name="vendor_margin_percent" readonly="1" string="Margin %"/>
                        </group>
                    </group>
                    <group>
                        <group string="Purchase Order Summary">
                            <field name="vendor_po_count" readonly="1"/>
                            <field name="vendor_po_total" readonly="1" widget="monetary"/>
                            <field name="vendor_po_paid_count" readonly="1"/>
                            <field name="vendor_po_pending_count" readonly="1"/>
                            <field name="vendor_payment_ratio" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Rating History" name="rating_history">
                            <field name="vendor_rating_ids" readonly="1" nolabel="1">
                                <list create="0" delete="0" edit="0"
                                      decoration-success="rating in ('4','5')"
                                      decoration-warning="rating == '3'"
                                      decoration-danger="rating in ('1','2')">
                                    <field name="purchase_order_id"/>
                                    <field name="rating"/>
                                    <field name="rating_value" string="Score"/>
                                    <field name="quality_rating"/>
                                    <field name="delivery_rating"/>
                                    <field name="pricing_rating"/>
                                    <field name="communication_rating"/>
                                    <field name="feedback"/>
                                    <field name="rated_by_id"/>
                                    <field name="rating_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ╔═══════════════════════════════════════════════════════════════╗
         ║  4. GRAPH — Stacked Sub-Rating Bar (most visually rich)       ║
         ╚═══════════════════════════════════════════════════════════════╝ -->
    <record id="view_vendor_dashboard_graph" model="ir.ui.view">
        <field name="name">res.partner.vendor.dashboard.graph</field>
        <field name="model">res.partner</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <!-- Stacked bar: each vendor shows Quality/Delivery/Pricing/Comms
                 as coloured stacked bars — much more visually informative than
                 a single avg-rating bar. User can switch to pie/line via the
                 Odoo graph type controls in the top toolbar. -->
            <graph string="Vendor Performance Breakdown" type="bar"
                   stacked="1" sample="1">
                <field name="name" string="Vendor"/>
                <field name="vendor_quality_avg" type="measure" string="Quality"/>
                <field name="vendor_delivery_avg" type="measure" string="Delivery"/>
                <field name="vendor_pricing_avg" type="measure" string="Pricing"/>
                <field name="vendor_communication_avg" type="measure" string="Communication"/>
                <field name="vendor_rating_avg" type="measure" string="Overall Avg"/>
                <field name="vendor_po_count" type="measure" string="PO Count"/>
                <field name="vendor_boq_line_count" type="measure" string="BOQ Lines"/>
            </graph>
        </field>
    </record>

    <!-- ╔═══════════════════════════════════════════════════════════════╗
         ║  5. PIVOT VIEW — Vendor Performance Table                     ║
         ╚═══════════════════════════════════════════════════════════════╝ -->
    <record id="view_vendor_dashboard_pivot" model="ir.ui.view">
        <field name="name">res.partner.vendor.dashboard.pivot</field>
        <field name="model">res.partner</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <pivot string="Vendor Performance" sample="1" display_quantity="true">
                <field name="name" type="row" string="Vendor"/>
                <field name="vendor_rating_status" type="col" string="Status"/>
                <field name="vendor_rating_avg" type="measure" string="Avg Rating"/>
                <field name="vendor_quality_avg" type="measure" string="Quality"/>
                <field name="vendor_delivery_avg" type="measure" string="Delivery"/>
                <field name="vendor_pricing_avg" type="measure" string="Pricing"/>
                <field name="vendor_communication_avg" type="measure" string="Communication"/>
                <field name="vendor_po_count" type="measure" string="POs"/>
                <field name="vendor_po_total" type="measure" string="PO Value"/>
                <field name="vendor_boq_line_count" type="measure" string="BOQ Lines"/>
            </pivot>
        </field>
    </record>

  
    <!-- ╔═══════════════════════════════════════════════════════════════╗
         ║  7. ACTION + VIEW BINDINGS                                    ║
         ╚═══════════════════════════════════════════════════════════════╝ -->
    <record id="action_vendor_dashboard" model="ir.actions.act_window">
        <field name="name">Vendor Dashboard</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,list,pivot,graph,form</field>
        <field name="domain">[('supplier_rank', '&gt;', 0)]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No vendors found.</p>
            <p>Vendors appear here once they have supplier rank &gt; 0. Assign vendors to BOQ trade tabs, create RFQs, and rate vendors after PO completion.</p>
        </field>
    </record>

