<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════
         BOQ MANAGEMENT — Application Menu (Odoo 19 Enterprise)
         ========================================================
         Task 1: Replaced single "Dashboard" menu with two separate pages:
           - "Vendor Manager Dashboard"      (seq 5)
           - "Procurement Manager Dashboard" (seq 6)
         Task 1: Vendor RFQ / Supplier RFQ split menus retained.
    ══════════════════════════════════════════════════════════ -->

    <!-- Root app menu -->
    <menuitem id="menu_boq_root"
              name="BOQ"
              sequence="85"
              web_icon="boq_management_v19,static/src/img/boq_icon.png"
              groups="boq_management_v19.group_boq_user"/>

    <!-- ── Task 1: TWO separate dashboard menu items ── -->
    <menuitem id="menu_vendor_manager_dashboard"
              name="Vendor Manager Dashboard"
              parent="menu_boq_root"
              action="action_vendor_manager_dashboard"
              sequence="5"
              groups="boq_management_v19.group_boq_user"/>

    <menuitem id="menu_procurement_manager_dashboard"
              name="Procurement Manager Dashboard"
              parent="menu_boq_root"
              action="action_procurement_manager_dashboard"
              sequence="6"
              groups="boq_management_v19.group_boq_user"/>

    <!-- ── Main BOQ section ── -->
    <menuitem id="menu_boq_main"
              name="BOQ"
              parent="menu_boq_root"
              sequence="10"/>

    <menuitem id="menu_boq_all"
              name="All BOQs"
              parent="menu_boq_main"
              action="action_boq_boq"
              sequence="10"/>

    <menuitem id="menu_boq_my"
              name="My BOQs"
              parent="menu_boq_main"
              action="action_boq_boq"
              sequence="20"/>

    <!-- ── RFQ section (Vendor + Supplier split) ── -->
    <menuitem id="menu_boq_rfq"
              name="RFQ"
              parent="menu_boq_root"
              sequence="30"/>

    <menuitem id="menu_boq_vendor_rfq"
              name="Vendor RFQ"
              parent="menu_boq_rfq"
              action="action_boq_rfq_list"
              sequence="10"
              groups="boq_management_v19.group_boq_user"/>

    <menuitem id="menu_boq_supplier_rfq"
              name="Supplier RFQ"
              parent="menu_boq_rfq"
              action="action_boq_supplier_rfq_list"
              sequence="20"
              groups="boq_management_v19.group_boq_user"/>

    <!-- ── Reporting section ── -->
    <menuitem id="menu_boq_report"
              name="Reporting"
              parent="menu_boq_root"
              sequence="50"
              groups="boq_management_v19.group_boq_manager"/>

    <menuitem id="menu_boq_vendor_list"
              name="Vendors"
              parent="menu_boq_report"
              action="action_boq_vendor_list"
              sequence="20"
              groups="boq_management_v19.group_boq_manager"/>

    <menuitem id="menu_boq_vendor_ratings"
              name="Vendor Ratings"
              parent="menu_boq_report"
              action="action_boq_vendor_rating"
              sequence="30"
              groups="boq_management_v19.group_boq_manager"/>

    <!-- ── Purchase app — Vendor RFQ / Supplier RFQ sub-menus ── -->
    <menuitem id="menu_purchase_boq_vendor_rfq"
              name="Vendor RFQ"
              parent="purchase.menu_purchase_rfq"
              action="boq_management_v19.action_boq_rfq_list"
              sequence="25"
              groups="purchase.group_purchase_user"/>

    <menuitem id="menu_purchase_boq_supplier_rfq"
              name="Supplier RFQ"
              parent="purchase.menu_purchase_rfq"
              action="boq_management_v19.action_boq_supplier_rfq_list"
              sequence="26"
              groups="purchase.group_purchase_user"/>

    <!-- ── Configuration section ── -->
    <menuitem id="menu_boq_config"
              name="Configuration"
              parent="menu_boq_root"
              sequence="90"
              groups="boq_management_v19.group_boq_manager"/>

    <menuitem id="menu_boq_categories"
              name="Work Categories"
              parent="menu_boq_config"
              action="action_boq_category"
              sequence="10"/>

</odoo>
