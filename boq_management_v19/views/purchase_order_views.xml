<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Task 3 — RFQ inside BOQ: form view inheritance only.
        List view inheritance removed — boq_id is non-stored computed;
        //list xpath hits nested lists in Odoo 19, causing ParseError.
    -->

    <record id="view_purchase_order_form_boq_inherit" model="ir.ui.view">
        <field name="name">purchase.order.form.boq.inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_boq" type="object"
                        class="oe_stat_button" icon="fa-calculator"
                        invisible="not boq_id" string="View BOQ">
                    <field name="boq_id" widget="statinfo" string="BOQ"/>
                </button>
                <!-- Vendor Rating stat button — shows rating or rate action -->
                <button name="action_view_rating" type="object"
                        class="oe_stat_button" icon="fa-star"
                        invisible="not vendor_rating_id">
                    <field name="vendor_rating_value" widget="statinfo" string="Rating"/>
                </button>
                <button name="action_rate_vendor" type="object"
                        class="oe_stat_button" icon="fa-star-o"
                        invisible="not can_rate_vendor"
                        string="Rate Vendor"/>
            </xpath>

            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="boq_id" string="BOQ Reference"
                       options="{'no_create': True}" invisible="not boq_id"/>
                <field name="vendor_payment_released" invisible="1"/>
                <field name="can_rate_vendor" invisible="1"/>
                <field name="vendor_rating_id" invisible="1"/>
            </xpath>

            <xpath expr="//field[@name='order_line']//field[@name='name']"
                   position="attributes">
                <attribute name="optional">show</attribute>
            </xpath>

            <!-- Vendor Rating section — visible when PO is confirmed -->
            <xpath expr="//field[@name='order_line']/.." position="after">
                <group string="Vendor Rating" invisible="state not in ('purchase', 'done')">
                    <group>
                        <div invisible="not vendor_rating_id" class="d-flex align-items-center gap-2">
                            <span class="fw-bold">Rating:</span>
                            <span class="badge bg-success fs-6" style="font-size:1rem !important;">
                                <field name="vendor_rating_value" readonly="1"/> / 5
                            </span>
                        </div>
                    </group>
                    <group>
                        <button name="action_rate_vendor" type="object"
                                string="Rate This Vendor"
                                class="btn btn-primary"
                                invisible="not can_rate_vendor"
                                icon="fa-star"/>
                        <button name="action_view_rating" type="object"
                                string="View Rating Details"
                                class="btn btn-link"
                                invisible="not vendor_rating_id"
                                icon="fa-star"/>
                    </group>
                </group>
            </xpath>

            <!-- Hide Approve button — not part of BOQ workflow -->
            <xpath expr="//button[@name='button_approve']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

        </field>
    </record>

    <record id="action_boq_rfq_list" model="ir.actions.act_window">
        <field name="name">RFQs from BOQ</field>
        <field name="res_model">purchase.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{'search_default_draft': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No RFQs linked to a BOQ yet!</p>
            <p>Open a BOQ, assign vendors to lines, then click <b>Create RFQ</b>.</p>
        </field>
    </record>

    <!-- ── Vendors list (suppliers that appear on BOQ lines) ─────────── -->
    <record id="action_boq_vendor_list" model="ir.actions.act_window">
        <field name="name">Vendors</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('supplier_rank', '&gt;', 0)]</field>
        <field name="context">{'search_default_supplier_rank': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No vendors found.</p>
            <p>Vendors are suppliers assigned on BOQ lines when creating RFQs.</p>
        </field>
    </record>

</odoo>
