<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════
         ALL INVENTORY ANALYSIS REPORTS — Menu Structure
         Path: Inventory > Reporting > Inventory Analysis Reports
    ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Sub-menu parent under Inventory > Reporting -->
    <menuitem
        id="menu_bi_inventory_analysis_root"
        name="Inventory Analysis Reports"
        parent="stock.menu_warehouse_report"
        sequence="25"/>

    <!-- 1. Current Stock Analysis -->
    <menuitem
        id="menu_bi_stock_inventory_report"
        name="Current Stock Analysis"
        parent="menu_bi_inventory_analysis_root"
        action="action_bi_stock_inventory_report"
        sequence="10"/>

    <!-- 2. Stock Movement Analysis -->
    <menuitem
        id="menu_bi_stock_move_report"
        name="Stock Movement Analysis"
        parent="menu_bi_inventory_analysis_root"
        action="action_bi_stock_move_report"
        sequence="20"/>

    <!-- 3. Inventory Aging Analysis -->
    <menuitem
        id="menu_bi_stock_aging_report"
        name="Inventory Aging Analysis"
        parent="menu_bi_inventory_analysis_root"
        action="action_bi_stock_aging_report"
        sequence="30"/>

    <!-- 4. Stock Valuation Report -->
    <menuitem
        id="menu_bi_stock_valuation_report"
        name="Stock Valuation Report"
        parent="menu_bi_inventory_analysis_root"
        action="action_bi_stock_valuation_report"
        sequence="40"/>

    <!-- 5. Dead / Slow-Moving Stock -->
    <menuitem
        id="menu_bi_stock_dead_report"
        name="Dead / Slow-Moving Stock"
        parent="menu_bi_inventory_analysis_root"
        action="action_bi_stock_dead_report"
        sequence="50"/>

    <!-- 6. Stock Expiry Report -->
    <menuitem
        id="menu_bi_stock_expiry_report"
        name="Stock Expiry Report"
        parent="menu_bi_inventory_analysis_root"
        action="action_bi_stock_expiry_report"
        sequence="60"/>

</odoo>
