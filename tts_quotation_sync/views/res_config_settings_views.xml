<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Standalone settings form — NOT inheriting the main Settings page.
        This means Save only validates OUR fields, so other modules' missing
        required fields cannot block Test Connection / Sync Now / Save.

        js_class="base_settings" ensures get_values() is called on load so
        all fields are populated from ir.config_parameter correctly.

        priority=999 ensures this view is never auto-selected as the default
        res.config.settings form — it is only opened via action_tts_config_settings.
    -->
    <record id="view_tts_config_settings_form" model="ir.ui.view">
        <field name="name">tts.quotation.sync.settings.form</field>
        <field name="model">res.config.settings</field>
        <field name="priority">999</field>
        <field name="arch" type="xml">
            <form string="Quotation Sync — Configuration" js_class="base_settings">

                <app string="Quotation Sync" name="tts_quotation_sync">

                    <block title="Connection settings" name="tts_connection">
                        <setting string="API Base URL"
                                 help="Quotation Builder backend endpoint">
                            <field name="tts_api_base_url"
                                   placeholder="https://quote.tinttoneandshades.com"/>
                        </setting>
                        <setting string="API Key (x-api-key)"
                                 help="API authentication key">
                            <field name="tts_api_key" password="True"
                                   placeholder="••••••••••••••••••"/>
                        </setting>
                        <setting string="Environment"
                                 help="Switch before going live">
                            <field name="tts_environment"/>
                        </setting>
                    </block>

                    <block title="Cron / auto-sync settings" name="tts_sync">
                        <setting string="Sync interval"
                                 help="How often Odoo polls the API">
                            <field name="tts_sync_interval"/>
                        </setting>
                        <setting string="Auto-create BOQ"
                                 help="Automatically create BOQ from the API data during each sync run">
                            <field name="tts_auto_create_boq"/>
                        </setting>
                        <setting string="Failure notification email"
                                 help="Notify when PUT returns Failure">
                            <field name="tts_failure_notification_email"/>
                        </setting>
                        <setting string="Default Customer"
                                 help="Customer placed on auto-created BOQs">
                            <field name="tts_default_customer_id"/>
                        </setting>
                    </block>

                    <block title="Actions" name="tts_actions">
                        <setting help="Verify the API connection is reachable">
                            <button type="object"
                                    name="action_test_connection"
                                    string="Test Connection"
                                    class="btn-secondary"/>
                        </setting>
                        <setting help="Fetch and process approved quotations now">
                            <button type="object"
                                    name="action_sync_now"
                                    string="Sync Now"
                                    class="btn-secondary"/>
                        </setting>
                    </block>

                    <block title="Records" name="tts_records">
                        <setting help="Open the list of all synced quotations">
                            <button type="object"
                                    name="action_view_quotations"
                                    string="View Quotations"
                                    class="btn-secondary"/>
                        </setting>
                        <setting help="Open sync history and error logs">
                            <button type="object"
                                    name="action_view_sync_logs"
                                    string="View Sync Logs"
                                    class="btn-secondary"/>
                        </setting>
                    </block>

                </app>

            </form>
        </field>
    </record>

    <!-- Opens ONLY the Quotation Sync settings page — isolated from other modules -->
    <record id="action_tts_config_settings" model="ir.actions.act_window">
        <field name="name">Quotation Sync</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_tts_config_settings_form"/>
        <field name="target">current</field>
        <field name="context">{'module': 'tts_quotation_sync'}</field>
    </record>

</odoo>
