    <record id="action_report_overstock" model="ir.actions.report">
        <field name="name">Overstock Analysis Report</field>
        <field name="model">inventory.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">tts_inventory_advanced_reports.report_overstock</field>
        <field name="report_file">tts_inventory_advanced_reports.report_overstock</field>
        <field name="print_report_name">'Overstock_Analysis_Report'</field>
