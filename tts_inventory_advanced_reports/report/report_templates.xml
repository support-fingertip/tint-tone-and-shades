    <record id="action_report_movement" model="ir.actions.report">
        <field name="name">Stock Movement Report</field>
        <field name="model">inventory.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">tts_inventory_advanced_reports.report_movement</field>
        <field name="report_file">tts_inventory_advanced_reports.report_movement</field>
        <field name="print_report_name">'Stock_Movement_Report'</field>
