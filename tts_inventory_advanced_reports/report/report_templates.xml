        <field name="report_type">qweb-pdf</field>
        <field name="report_name">tts_inventory_advanced_reports.report_out_of_stock</field>
        <field name="report_file">tts_inventory_advanced_reports.report_out_of_stock</field>
        <field name="print_report_name">'Out_of_Stock_Analysis_Report'</field>
