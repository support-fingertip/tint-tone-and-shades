<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Wizard form view ──────────────────────────────────────────────── -->
    <record id="view_inventory_report_wizard_form" model="ir.ui.view">
        <field name="name">inventory.report.wizard.form</field>
        <field name="model">inventory.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Inventory Advanced Reports">
                <sheet>
                    <div class="oe_title">
                        <h1>Inventory Advanced Reports</h1>
                        <p class="text-muted">
                            Select a report type, set your filters, then print to PDF or export to Excel.
                        </p>
                    </div>

                    <group>
                        <group string="Report">
                            <field name="report_type" widget="radio"/>
                        </group>
                        <group string="Filters">
                            <field name="company_id"/>
                            <field name="warehouse_id"
                                   domain="[('company_id','=',company_id)]"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="product_ids" widget="many2many_tags"/>
                            <field name="category_ids" widget="many2many_tags"/>
                        </group>
                    </group>

                    <!-- Aging / Breakdown options -->
                    <group string="Aging Thresholds"
                           attrs="{'invisible': [('report_type','not in',['aging','age_breakdown'])]}">
                        <group>
                            <field name="aging_threshold_1"/>
                            <field name="aging_threshold_2"/>
                            <field name="aging_threshold_3"/>
                        </group>
                    </group>

                    <!-- FSN options -->
                    <group string="FSN Parameters"
                           attrs="{'invisible': [('report_type','not in',['fsn','fsn_xyz'])]}">
                        <group>
                            <field name="fsn_fast_pct"
                                   help="Daily rate as % of max rate; at or above this = Fast"/>
                        </group>
                    </group>

                    <!-- XYZ options -->
                    <group string="XYZ Thresholds"
                           attrs="{'invisible': [('report_type','not in',['xyz','fsn_xyz'])]}">
                        <group>
                            <field name="xyz_x_pct"/>
                            <field name="xyz_y_pct"/>
                        </group>
                    </group>

                    <!-- Coverage options -->
                    <group string="Coverage Parameters"
                           attrs="{'invisible': [('report_type','not in',['overstock','out_of_stock'])]}">
                        <group>
                            <field name="coverage_days"/>
                        </group>
                    </group>
                </sheet>

                <footer>
                    <button name="action_print_pdf"
                            type="object"
                            string="Print PDF"
                            class="btn-primary"
                            icon="fa-print"/>
                    <button name="action_export_excel"
                            type="object"
                            string="Export Excel"
                            class="btn-secondary"
                            icon="fa-file-excel-o"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ── Client action to open the wizard ─────────────────────────────── -->
    <record id="action_inventory_report_wizard" model="ir.actions.act_window">
        <field name="name">Inventory Advanced Reports</field>
        <field name="res_model">inventory.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_inventory_report_wizard_form"/>
        <field name="target">new</field>
    </record>

</odoo>
